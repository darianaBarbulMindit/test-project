{
  "name": "test-project",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "table-app",
    "api"
  ],
  "scripts": {
    "dev": "concurrently -k \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "npm run start --workspace table-app",
    "dev:api": "npm run dev --workspace table-api",
    "build": "npm run build:web",
    "build:web": "npm run build --workspace table-app",
    "start": "npm run start --workspace table-api"
  },
  "dependencies": {
    "@databricks/sql": "^1.12.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
